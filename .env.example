# Robertson Doctrine — Environment Variables
# Copy this file to .env and edit as needed

# Port for the Express server (default: 8420)
PORT=8420

# How long to cache FRED data in milliseconds (default: 3600000 = 1 hour)
CACHE_TTL_MS=3600000

# FRED API key (optional — used if provided for higher rate limits)
# Get a free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_key_here
